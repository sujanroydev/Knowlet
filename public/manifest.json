{
  "name": "Knowlet",
  "short_name": "Knowlet",
  "description": "Knowlet: A platform for students to explore and learn.",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "lang": "en",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "theme_color": "#ffffff",
  "background_color": "#ffffff",

  "icons": [
    {
      "src": "/icons/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name": "Nexus",
      "short_name": "Nexus",
      "description": "Open Nexus",
      "url": "/nexus",
      "icons": [
        {
          "src": "/icons/nexus/web-app-manifest-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        },
        {
          "src": "/icons/nexus/web-app-manifest-512x512.png",
          "sizes": "512x512",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],

  "screenshots": [
    {
      "src": "/screenshots/mobile-home.jpg",
      "sizes": "1080x2408",
      "type": "image/jpeg",
      "label": "Knowlet mobile homepage"
    },
    {
      "src": "/screenshots/desktop-home.png",
      "sizes": "1630x945",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Knowlet desktop dashboard"
    }
  ]
}
